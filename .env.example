# CODOS Observatory — API keys (local development)
#
# Copy this file to `.env` and fill in your keys:   cp .env.example .env
# `.env` is gitignored — NEVER commit real keys.
# In CI, set these as GitHub Actions repository *secrets* instead (see README).

# Exa — weekly news / signal search · https://exa.ai
EXA_API_KEY=your-exa-key-here

# Firecrawl — competitor site change-tracking · https://firecrawl.dev
FIRECRAWL_API_KEY=fc-your-firecrawl-key-here

# Google Gemini — insight synthesis · https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-key-here
